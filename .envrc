# SOV — direnv configuration
#
# This file is committed. It declares which environment variables the
# project consumes; the actual values live in a per-collaborator
# `.envrc.local` (gitignored) that you create from `.envrc.example`.
#
# Policy: ADR 0006. Setup: `cp .envrc.example .envrc.local && direnv allow`.

# Load per-collaborator secrets if present. `dotenv_if_exists` reads a
# .env-format file; `source_env_if_exists` is the equivalent for files
# that contain shell `export` statements (which is what `.envrc.example`
# produces). We support either flavour.
dotenv_if_exists .envrc.local
source_env_if_exists .envrc.local

# Helper: warn if a required variable for the current phase is missing.
# Used by sub-track `.envrc` files via `require_var NAME purpose`.
require_var() {
  local name="$1"
  local purpose="${2:-required}"
  if [[ -z "${!name:-}" ]]; then
    log_status "  warning: \$${name} unset (${purpose}). Add to .envrc.local."
  fi
}
export -f require_var 2>/dev/null || true
