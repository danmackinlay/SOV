# SOV — phases-apple direnv configuration
#
# This file is committed. It inherits secrets from the repo-root .envrc
# (which sources .envrc.local) via source_up, then warns about any
# apple-track-specific vars that are unset.
#
# Policy: ADR 0006. Per-collaborator secrets go in `.envrc.local` at
# the repo root, NOT here.

source_up

# Phase-0 minimum.
require_var HF_TOKEN "phase 0: needed to pull gated models from mlx-community"

# Optional: Anthropic / OpenAI for LiteLLM cloud routing (phase 1+).
# require_var ANTHROPIC_API_KEY "phase 1: cloud routing via LiteLLM"

# Apple-side hygiene defaults. Not secrets; just consistent across
# collaborators. Override in .envrc.local if you want different.
export OLLAMA_KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-15m}"

# Note: we deliberately do NOT export HOST here, even though LiteLLM's
# --host flag reads it via Click's `envvar="HOST"`. HOST is far too
# generic to scope project-wide — macOS shells / ssh tooling / web
# frameworks all read it. The loopback-binding discipline lives in
# bin/litellm-start.sh instead, which scopes HOST=127.0.0.1 to the
# litellm subprocess only.

# Phase 1 onward: OpenAI-compatible clients (Aider, opencode, any
# script using the openai SDK) discover the local stack via these env
# vars. The base URL is project-fixed (LiteLLM proxy bound to 4000 by
# the wrapper); only the key is per-collaborator and belongs in
# .envrc.local. At phase 1 LiteLLM doesn't actually validate the key
# so "anything" works; phase 2 introduces master-key gating.
export OPENAI_API_BASE="${OPENAI_API_BASE:-http://127.0.0.1:4000/v1}"
# OPENAI_API_KEY: set in .envrc.local. See .envrc.example for the
# phase-1 dummy / phase-2 master-key guidance.
