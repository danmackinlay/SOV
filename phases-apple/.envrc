# SOV — phases-apple direnv configuration
#
# This file is committed. It inherits secrets from the repo-root .envrc
# (which sources .envrc.local) via source_up, then warns about any
# apple-track-specific vars that are unset.
#
# Policy: ADR 0006. Per-collaborator secrets go in `.envrc.local` at
# the repo root, NOT here.

source_up

# Phase-0 minimum.
require_var HF_TOKEN "phase 0: needed to pull gated models from mlx-community"

# Optional: Anthropic / OpenAI for LiteLLM cloud routing (phase 1+).
# require_var ANTHROPIC_API_KEY "phase 1: cloud routing via LiteLLM"

# Apple-side hygiene defaults. Not secrets; just consistent across
# collaborators. Override in .envrc.local if you want different.
export OLLAMA_KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-15m}"

# LiteLLM defaults to --host 0.0.0.0 (all interfaces). Setting HOST here
# flips the default to loopback-only via LiteLLM's `envvar="HOST"` Click
# option. The CLI flag (--host 127.0.0.1) overrides this if you ever
# need a different bind for testing. There is no YAML-config equivalent.
# Note: this only protects you when cwd is anywhere under phases-apple/;
# for repo-root cwd, mirror this export in your .envrc.local.
export HOST="${HOST:-127.0.0.1}"
