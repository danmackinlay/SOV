# SOV — phases-cloud direnv configuration
#
# This file is committed. It inherits secrets from the repo-root .envrc
# (which sources .envrc.local) via source_up, then warns about any
# cloud-track-specific vars that are unset.
#
# Policy: ADR 0006. Per-collaborator secrets go in `.envrc.local` at
# the repo root, NOT here.

source_up

# Phase-0 minimum.
require_var RUNPOD_API_KEY "phase 0: needed to launch RunPod pods"
require_var HF_TOKEN       "phase 0: needed to pull gated models"

# Optional cross-stack routing (phase 2 onward).
# require_var ANTHROPIC_API_KEY "phase 2: cloud routing via LiteLLM"
